# =============================================================
# vROps Alert AutoCaller — 環境設定檔
# 首次部署時由 install.sh 自動產生，之後可手動修改
# 修改後執行：systemctl restart vrops-alert-caller
# =============================================================

# Webhook 接收設定
webhook:
  host: "0.0.0.0"
  port: 5000
  auth_token: "CHANGE_ME_WEBHOOK_TOKEN"  # vROps Webhook 驗證 Token

# TTS 語音合成設定
tts:
  engine: "edge-tts"                     # edge-tts（需網路）| gtts | pyttsx3（離線）
  voice: "zh-TW-HsiaoChenNeural"         # 台灣女聲
  output_dir: "/opt/vrops-alert-caller/audio"
  fallback_wav: "/opt/vrops-alert-caller/audio/fallback_alert.wav"

# SIP 撥號設定
# 支援任何標準 SIP Trunk 提供商（EZUC+、Twilio SIP Trunk、FreePBX、Asterisk 等）
# 若使用 Twilio 後端則此區塊可留預設值（不會被使用）
sip:
  server: "CHANGE_ME_SIP_SERVER"        # SIP 伺服器位址，如 sip.example.com
  port: 5061                            # TLS 通常為 5061；UDP/TCP 通常為 5060
  transport: "tls"                      # tls（推薦）| udp | tcp
  username: "CHANGE_ME_SIP_USER"        # SIP 帳號（Username）
  password: "CHANGE_ME_SIP_PASS"        # SIP 密碼

# 告警處理參數
alert:
  dedup_window_seconds: 300             # 去重視窗（秒）：同一告警 5 分鐘內不重播
  max_retry: 3                          # 未接最多重撥次數
  retry_interval_seconds: 120           # 重撥間隔（秒）
  escalation: true                      # 全部未接後升級到下一位
  queue_ttl_seconds: 600                # Queue 存活上限（秒），超過丟棄
  batch_threshold: 3                    # 積壓超過此數觸發風暴合併

# WebGUI 管理介面
webgui:
  secret_key: "CHANGE_ME_RANDOM_SECRET" # Flask Session 加密金鑰（隨機字串）
  users:
    admin: "CHANGE_ME_ADMIN_PASS"       # 管理員密碼

# Twilio 外撥設定（與 SIP 二選一，預設停用）
# 啟用後系統改用 Twilio REST API 撥出電話，不再使用 pjsua2/SIP
twilio:
  enabled: false                        # true = 改用 Twilio；false = 使用 SIP（預設）
  account_sid: "CHANGE_ME_ACCOUNT_SID"  # Twilio Console → Account Info → Account SID
  auth_token: "CHANGE_ME_AUTH_TOKEN"    # Twilio Console → Account Info → Auth Token
  from_number: "+1XXXXXXXXXX"           # 購買或驗證的 Twilio 電話號碼（E.164 格式）
  public_base_url: "https://your-server.example.com"
  # ↑ 本服務對外可連線的 HTTPS URL（Twilio 需能呼叫 /twiml/ 及 /audio/ 端點）
  #   若使用 ngrok 測試：https://xxxx.ngrok-free.app

# nginx 反向代理 + HTTPS 設定
# install.sh 安裝時自動設定；也可在 WebGUI「設定」→「HTTPS / SSL」頁面管理
nginx:
  enabled: false                        # true = 已安裝 nginx 反向代理
  domain: ""                            # 對外域名（如 vrops.myddns.me）
  # 憑證由 certbot 自動管理（Let's Encrypt）
  # 或手動上傳至 /opt/vrops-alert-caller/ssl/fullchain.pem + privkey.pem

# 日誌設定
logging:
  file: "/opt/vrops-alert-caller/logs/app.log"
  level: "INFO"                         # DEBUG | INFO | WARNING | ERROR
  db_path: "/opt/vrops-alert-caller/logs/alerts.db"
